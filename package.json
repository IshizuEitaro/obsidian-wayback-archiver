{
	"name": "wayback-archiver",
	"version": "1.1.3",
	"description": "Automatically archives web links via Wayback Machine and appends archived versions in notes.",
	"keywords": [
		"archiving",
		"obsidian-md",
		"obsidian-plugin",
		"wayback-machine"
	],
	"license": "MIT",
	"author": "ISHIZUE",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest",
		"lint": "oxlint . --type-aware",
		"format": "oxfmt .",
		"format:check": "oxfmt --check ."
	},
	"dependencies": {
		"date-fns": "4.1.0"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "6.9.1",
		"@types/node": "25.5.0",
		"@vitest/ui": "4.1.0",
		"builtin-modules": "5.0.0",
		"esbuild": "0.27.4",
		"jsdom": "29.0.0",
		"obsidian": "1.12.3",
		"oxfmt": "0.41.0",
		"oxlint": "1.56.0",
		"oxlint-tsgolint": "0.17.0",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"vite": "8.0.0",
		"vitest": "4.1.0"
	},
	"engines": {
		"node": ">=22 <26",
		"pnpm": "10.32.1"
	},
	"pnpm": {
		"overrides": {
			"minimatch": "10.2.4",
			"ajv": "6.14.0",
			"flatted@<3.4.0": ">=3.4.0"
		}
	}
}
